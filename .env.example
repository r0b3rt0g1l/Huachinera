# Web3Forms — endpoint para formularios de contacto y solicitud de información pública.
# Servidor (referenciada desde lib/municipalConfig.js -> servicios.web3FormsKey):
WEB3FORMS_ACCESS_KEY=

# Cliente (referenciada desde componentes de formulario en app/contacto y
# app/transparencia/informacion-publica). Mismo valor que WEB3FORMS_ACCESS_KEY
# salvo que se separe en dos cuentas de Web3Forms.
NEXT_PUBLIC_WEB3FORMS_KEY=

# Slug del municipio que representa este sitio. Lo consume lib/cms.js para
# armar los endpoints /api/municipios/<slug>/... Cambia este valor por municipio.
NEXT_PUBLIC_MUNICIPIO_SLUG=municipio

# URL canónica del sitio (usada por sitemap, robots y SEO).
NEXT_PUBLIC_SITE_URL=https://municipio.example.com

# Backend CMS. Lo consumen los helpers de lib/cms.js para hero, noticias,
# imágenes, documentos, SEvAC y cabildo. En local apunta a http://localhost:3000
# si tienes el backend levantado. Déjalo vacío para usar solo los fallbacks estáticos.
NEXT_PUBLIC_API_URL=
