# Web3Forms — endpoint para formularios de contacto y solicitud de información pública.
# Servidor (referenciada desde lib/municipalConfig.js -> servicios.web3FormsKey):
WEB3FORMS_ACCESS_KEY=

# Cliente (referenciada desde componentes de formulario en app/contacto y
# app/transparencia/informacion-publica). Mismo valor que WEB3FORMS_ACCESS_KEY
# salvo que se separe en dos cuentas de Web3Forms.
NEXT_PUBLIC_WEB3FORMS_KEY=

# Slug del municipio. OBLIGATORIO en build time (lib/cms.js lo hornea y lanza
# error si falta o vale "municipio"). En Vercel: Settings → Environment Variables.
NEXT_PUBLIC_MUNICIPIO_SLUG=huachinera

# URL canónica del sitio (sitemap, robots, SEO). Provisional hasta dominio oficial.
NEXT_PUBLIC_SITE_URL=https://huachinera-gobierno.vercel.app

# Backend CMS multi-municipio. Producción: https://cmsmunicipal.onrender.com
# OBLIGATORIO en build de Vercel (lib/cms.js GUARD 2). En local puede ir vacío
# para usar solo los fallbacks estáticos.
NEXT_PUBLIC_API_URL=
